                </div>
                
                <div class="glass-card mb-4" style="border-left: 4px solid var(--primary); padding: 12px;">
                    <p id="mentor-greeting" style="font-style: italic; color: var(--text-muted); font-size: 0.85rem;">"I've analyzed your latest telemetry. Let's talk about what's on your mind."</p>
                </div>

                <div class="chat-container glass-card" style="height: 350px; display: flex; flex-direction: column;">
                    <div id="mentor-chat-messages" class="chat-messages p-4" style="flex: 1; overflow-y: auto; font-size: 0.9rem;">
                        <div class="msg msg-ai">I am here for you. How are you feeling right now?</div>
                    </div>
                    <div class="p-3 d-flex gap-2" style="border-top: 1px solid rgba(0,0,0,0.05);">
                        <input type="text" id="mentor-chat-input" class="input-field" placeholder="Type here..." style="margin-bottom: 0; font-size: 0.8rem;">
                        <button class="btn btn-primary" id="mentor-send-btn" style="padding: 8px 16px;">Send</button>
                    </div>
                </div>
            </div>
        </div>

        <!-- VIEW 70: THOUGHT OF THE DAY (MODAL) -->
        <div id="view-70-thought" class="view" style="background: rgba(255,255,255,0.9); backdrop-filter: blur(10px); justify-content: center; z-index: 200;">
            <div class="glass-card text-center p-8" style="border: 4px solid var(--primary); animation: popIn 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);">
                <div style="font-size: 3rem; margin-bottom: 20px;">✨</div>
                <h2 class="mb-4 text-gradient" style="font-size: 1.8rem;">Thought of the Day</h2>
                <p id="daily-quote" style="font-size: 1.2rem; font-weight: 500; color: var(--text-main); line-height: 1.6; margin-bottom: 32px;">"Your mind is like a garden; your thoughts are the seeds. You can grow flowers or you can grow weeds."</p>
                <button class="btn btn-primary" onclick="navigate('16-dashboard-main')">Let's Flourish</button>
            </div>
        </div>

        <script src="app.js"></script>
    <script type="module" src="firebase-main.js"></script>
</body>

</html>