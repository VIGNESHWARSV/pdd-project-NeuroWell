<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>NeuroWell AI - Serenity SPA</title>
    <link rel="icon" type="image/png" href="logo.png">
    <link rel="stylesheet" href="style.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.6.0/dist/confetti.browser.min.js"></script>
    <script>
        window.navigate = function(targetId) {
            console.log("Navigating to:", targetId);
            document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
            const target = document.getElementById('view-' + targetId);
            if(target) target.classList.add('active');
            
            // Trigger dashboard metrics when opening the dashboard
            if(targetId === '16-dashboard-main' && window.fetchDashboardMetrics) {
                window.fetchDashboardMetrics();
            }
            
            // Auto-initialize biometrics based on view
            if(targetId === '8-biometric-login' && window.setupFingerprint) window.setupFingerprint();
            if(targetId === '22-voice-input' && window.setupVoice) window.setupVoice();
            if(targetId === '25-face-scan' && window.setupCamera) window.setupCamera();
            if(targetId === '28-combined-analysis' && window.startMultimodalSync) window.startMultimodalSync();
            if(targetId === '52-fingerprint-scan' && window.setupFingerprintScan) window.setupFingerprintScan();
            
            // Highlight active nav item
            document.querySelectorAll('.nav-item').forEach(item => {
                if(item.getAttribute('data-target') === targetId) {
                    item.classList.add('active');
                } else {
                    item.classList.remove('active');
                }
            });

            const bottomNav = document.getElementById('bottom-nav');
            if(bottomNav) {
                const hideNavScreens = ['1-splash', '2-welcome', '3-login', '4-signup', '5-otp', '6-forgot-password', '7-reset-password', '8-biometric-login', 
                                         '9-onboarding-1', '10-onboarding-2', '11-onboarding-3', '12-user-info', '13-questionnaire', '14-goals', '15-notifications',
                                         '22-voice-input', '23-voice-recording', '24-voice-processing', '42-chat-conversation', '51-subscription-plans',
                                         '52-fingerprint-scan', '55-biometric-result'];
                bottomNav.style.display = hideNavScreens.includes(targetId) ? 'none' : 'flex';
            }
        }
    </script>
</head>

<body>
    <div id="app">
        <div class="shape-3"></div>
        
        <!-- Music Control -->
        <div id="music-control" onclick="toggleMusic()">
            <span id="music-icon">🎵</span>
        </div>

        <audio id="bg-music" loop>
            <source src="https://www.soundhelix.com/examples/mp3/SoundHelix-Song-2.mp3" type="audio/mpeg">
        </audio>

        <div id="view-1-splash" class="view active">

            <div class="logo-container mx-auto mt-8 mb-4" onclick="navigate('2-welcome')">
                <img class="logo-icon" src="logo.png"
                    style="border-radius:50%; object-fit:cover; padding:5px; background:var(--glass-bg);">
            </div>
            <h1 class="text-center">NeuroWell <span class="text-gradient">AI</span></h1>
            <p class="text-center text-muted mt-2">Harmonizing Mind & Environment</p>
            <div class="glass-card mt-8 mx-auto" style="width: 80%; text-align: center;">
                <p class="text-muted" style="font-size: 0.8rem;">Featuring Exclusive:</p>
                <p class="text-primary mt-2">✦ Subconscious Biometric Sync</p>
                <p class="text-primary mt-2">✦ Neural-Acoustic Therapy</p>
                <p class="text-primary mt-2">✦ Ambient Environment Engine</p>
                <a href="#" onclick="navigate('2-welcome'); return false;" class="text-muted mt-4 d-block" style="font-size: 0.7rem; text-decoration: underline;">Stuck? Click here to enter</a>
            </div>

            <!-- Social Links -->
            <div class="social-links">
                <a href="https://instagram.com" target="_blank" class="social-icon instagram"><i class="fab fa-instagram"></i></a>
                <a href="https://wa.me/" target="_blank" class="social-icon whatsapp"><i class="fab fa-whatsapp"></i></a>
                <a href="https://facebook.com" target="_blank" class="social-icon facebook"><i class="fab fa-facebook"></i></a>
            </div>

        </div>

        <div id="view-2-welcome" class="view">

            <div class="header">
                <h2>Welcome to Serenity</h2>
            </div>
            <div class="glass-card mt-8 text-center"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <p class="mb-4">Your private space for gentle emotional intelligence.</p>
                <button class="btn btn-primary mb-4" onclick="navigate('3-login')">Login</button>
                <button class="btn btn-glass" onclick="navigate('4-signup')">Sign Up</button>
            </div>

        </div>

        <div id="view-3-login" class="view">
            <div class="header">
                <button class="back-btn" onclick="navigate('2-welcome')">←</button>
                <h2>Login</h2>
                <div></div>
            </div>
            <div class="glass-card mt-4" style="flex:1;">
                <input type="email" id="login-email" class="input-field mb-4" placeholder="Email">
                <input type="password" id="login-password" class="input-field mb-4" placeholder="Password">
                <button class="btn btn-primary w-100" id="login-btn">Sign In</button>
                <a href="#" class="d-block mt-4 text-primary" onclick="navigate('8-biometric-login'); return false;">Use Face ID / Fingerprint</a>
            </div>
        </div>
        <div id="view-4-signup" class="view">

            <div class="header">
                <button class="back-btn" onclick="navigate('16-dashboard-main')">←</button>
                <h2>Signup</h2>
                <div></div>
            </div>
            <div class="glass-card text-center mt-4"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <img src="logo.png" class="logo-icon mx-auto mb-4"
                    style="width:60px; height:60px; border-radius:50%;">
                <h3>Create Account</h3>
                <div class="text-left mt-4" style="width: 100%;">
                    <input type="text" id="signup-name" class="input-field mb-4" placeholder="Full Name">
                    <input type="email" id="signup-email" class="input-field mb-4" placeholder="Email">
                    <input type="password" id="signup-password" class="input-field mb-4" placeholder="Password">
                    <button id="signup-btn" class="btn btn-primary w-100">Sign Up</button>
                </div>
                <p class="text-muted mt-4" style="font-size: 0.8rem;">By signing up, you agree to our Privacy Policy.</p>
            </div>

        </div>

        <div id="view-5-otp" class="view">

            <div class="header">
                <button class="back-btn" onclick="navigate('16-dashboard-main')">←</button>
                <h2>OTP Verification</h2>
                <div></div>
            </div>
            <div class="glass-card text-center mt-4"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <img src="logo.png" class="logo-icon mx-auto mb-4"
                    style="width:60px; height:60px; opacity:0.5; filter: grayscale(1); border-radius:50%;">
                <h3>OTP Verification</h3>
                <p class="text-muted mt-4">Screen template resting peacefully.</p>
            </div>

        </div>

        <div id="view-6-forgot-password" class="view">

            <div class="header">
                <button class="back-btn" onclick="navigate('16-dashboard-main')">←</button>
                <h2>Forgot Password</h2>
                <div></div>
            </div>
            <div class="glass-card text-center mt-4"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <img src="logo.png" class="logo-icon mx-auto mb-4"
                    style="width:60px; height:60px; border-radius:50%;">
                <h3>Reset Password</h3>
                <p class="text-muted mt-2 mb-6">Enter your email and we'll send you a link to reset your password.</p>
                <input type="email" id="forgot-email" class="input-field mb-4" placeholder="Email Address">
                <button id="forgot-btn" class="btn btn-primary w-100">Send Reset Link</button>
            </div>

        </div>

        <div id="view-7-reset-password" class="view">

            <div class="header">
                <button class="back-btn" onclick="navigate('16-dashboard-main')">←</button>
                <h2>Reset Password</h2>
                <div></div>
            </div>
            <div class="glass-card text-center mt-4"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <img src="logo.png" class="logo-icon mx-auto mb-4"
                    style="width:60px; height:60px; opacity:0.5; filter: grayscale(1); border-radius:50%;">
                <h3>Reset Password</h3>
                <p class="text-muted mt-4">Screen template resting peacefully.</p>
            </div>

        </div>

        <div id="view-8-biometric-login" class="view">
            <div class="header">
                <button class="back-btn" onclick="navigate('3-login')">←</button>
                <h2>Biometric Login</h2>
                <div></div>
            </div>
            <div class="glass-card text-center mt-4"
                style="flex:1; display:flex; flex-direction:column; justify-content:center; align-items:center;">
                <div id="fingerprint-btn" class="logo-icon mx-auto mb-4"
                    style="font-size:3rem; cursor:pointer; filter:none; opacity:1; width:100px; height:100px;">👆</div>
                <h3>Fingerprint / Face ID</h3>
                <p class="text-muted mt-4" id="webauthn-status">Tap the icon to authenticate securely via WebAuthn.</p>
            </div>
        </div>
        <div id="view-9-onboarding-1" class="view">

            <div class="header">
                <h2>Onboarding 1 (Intro)</h2>
            </div>
            <div class="glass-card text-center"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <h3 class="mb-4">Step 1</h3>
                <p class="text-muted mb-8">We are setting up your personalized environmental and biometric baseline.</p>
                <button class="btn btn-primary" onclick="navigate('10-onboarding-2')">Continue Gently</button>
            </div>

        </div>

        <div id="view-10-onboarding-2" class="view">

            <div class="header">
                <h2>Onboarding 2 (Features)</h2>
            </div>
            <div class="glass-card text-center"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <h3 class="mb-4">Step 2</h3>
                <p class="text-muted mb-8">We are setting up your personalized environmental and biometric baseline.</p>
                <button class="btn btn-primary" onclick="navigate('11-onboarding-3')">Continue Gently</button>
            </div>

        </div>

        <div id="view-11-onboarding-3" class="view">

            <div class="header">
                <h2>Onboarding 3 (Privacy)</h2>
            </div>
            <div class="glass-card text-center"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <h3 class="mb-4">Step 3</h3>
                <p class="text-muted mb-8">We are setting up your personalized environmental and biometric baseline.</p>
                <button class="btn btn-primary" onclick="navigate('12-user-info')">Continue Gently</button>
            </div>

        </div>

        <div id="view-12-user-info" class="view">

            <div class="header">
                <button class="back-btn" onclick="navigate('16-dashboard-main')">←</button>
                <h2>User Info Form</h2>
                <div></div>
            </div>
            <div class="glass-card text-center mt-4"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <img src="logo.png" class="logo-icon mx-auto mb-4"
                    style="width:60px; height:60px; border-radius:50%;">
                <h3>Complete Your Profile</h3>
                <div class="text-left mt-4" style="width: 100%;">
                    <label class="text-muted" style="font-size: 0.8rem; margin-left: 10px;">Age</label>
                    <input type="number" id="profile-age" class="input-field mb-4" placeholder="Age">
                    
                    <label class="text-muted" style="font-size: 0.8rem; margin-left: 10px;">Gender</label>
                    <select id="profile-gender" class="input-field mb-4" style="appearance: none;">
                        <option value="">Select Gender</option>
                        <option value="male">Male</option>
                        <option value="female">Female</option>
                        <option value="other">Other</option>
                        <option value="prefer-not-to-say">Prefer not to say</option>
                    </select>
                    
                    <button id="profile-save-btn" class="btn btn-primary w-100">Save & Continue</button>
                </div>
            </div>

        </div>

        <div id="view-13-questionnaire" class="view">

            <div class="header">
                <button class="back-btn" onclick="navigate('16-dashboard-main')">←</button>
                <h2>Mental Health Questionnaire</h2>
                <div></div>
            </div>
            <div class="glass-card text-center mt-4"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <h3>Current State</h3>
                <p class="text-muted mb-6">How are you feeling right now?</p>
                
                <div class="text-left" style="width: 100%;">
                    <p class="mb-2" style="font-size: 0.9rem;">Stress Level (1-10)</p>
                    <input type="range" id="q-stress" min="1" max="10" value="5" class="w-100 mb-4">
                    
                    <p class="mb-2" style="font-size: 0.9rem;">Sleep Quality (1-10)</p>
                    <input type="range" id="q-sleep" min="1" max="10" value="7" class="w-100 mb-4">
                    
                    <p class="mb-2" style="font-size: 0.9rem;">Mood Score (1-10)</p>
                    <input type="range" id="q-mood" min="1" max="10" value="6" class="w-100 mb-4">
                    
                    <p class="mb-2" style="font-size: 0.9rem;">Anxiety Level (1-10)</p>
                    <input type="range" id="q-anxiety" min="1" max="10" value="3" class="w-100 mb-6">
                    
                    <button id="q-save-btn" class="btn btn-primary w-100">Submit Assessment</button>
                </div>
            </div>

        </div>

        <div id="view-14-goals" class="view">

            <div class="header">
                <button class="back-btn" onclick="navigate('16-dashboard-main')">←</button>
                <h2>Goal Selection</h2>
                <div></div>
            </div>
            <div class="glass-card text-center mt-4"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <h3>Personal Goals</h3>
                <p class="text-muted mb-6">What would you like to focus on?</p>
                
                <div class="goals-selection text-left" style="width: 100%;">
                    <label class="glass-card mb-3 d-flex align-items-center" style="display: flex; align-items: center; padding: 12px; cursor: pointer;">
                        <input type="checkbox" name="goal" value="Reduce Stress" style="margin-right: 12px; width: 20px; height: 20px;">
                        <span>Reduce Stress</span>
                    </label>
                    <label class="glass-card mb-3 d-flex align-items-center" style="display: flex; align-items: center; padding: 12px; cursor: pointer;">
                        <input type="checkbox" name="goal" value="Improve Sleep" style="margin-right: 12px; width: 20px; height: 20px;">
                        <span>Improve Sleep</span>
                    </label>
                    <label class="glass-card mb-3 d-flex align-items-center" style="display: flex; align-items: center; padding: 12px; cursor: pointer;">
                        <input type="checkbox" name="goal" value="Track Mood" style="margin-right: 12px; width: 20px; height: 20px;">
                        <span>Track Mood</span>
                    </label>
                    <label class="glass-card mb-3 d-flex align-items-center" style="display: flex; align-items: center; padding: 12px; cursor: pointer;">
                        <input type="checkbox" name="goal" value="Better Focus" style="margin-right: 12px; width: 20px; height: 20px;">
                        <span>Better Focus</span>
                    </label>
                    
                    <button id="goals-save-btn" class="btn btn-primary w-100 mt-4">Confirm Goals</button>
                </div>
            </div>

        </div>

        <div id="view-15-notifications" class="view">

            <div class="header">
                <button class="back-btn" onclick="navigate('16-dashboard-main')">←</button>
                <h2>Notification Preferences</h2>
                <div></div>
            </div>
            <div class="glass-card text-center mt-4"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <h3>Reminders</h3>
                <p class="text-muted mb-6">Stay connected with your progress.</p>
                
                <div class="notifications-settings text-left" style="width: 100%;">
                    <label class="glass-card mb-3 d-flex align-items-center" style="display: flex; align-items: center; padding: 12px; justify-content: space-between;">
                        <span>Daily Reminder</span>
                        <input type="checkbox" id="pref-daily" checked style="width: 20px; height: 20px;">
                    </label>
                    <label class="glass-card mb-3 d-flex align-items-center" style="display: flex; align-items: center; padding: 12px; justify-content: space-between;">
                        <span>Weekly Report</span>
                        <input type="checkbox" id="pref-weekly" checked style="width: 20px; height: 20px;">
                    </label>
                    <label class="glass-card mb-3 d-flex align-items-center" style="display: flex; align-items: center; padding: 12px; justify-content: space-between;">
                        <span>Meditation Reminder</span>
                        <input type="checkbox" id="pref-meditation" style="width: 20px; height: 20px;">
                    </label>
                    
                    <button id="prefs-save-btn" class="btn btn-primary w-100 mt-4">All Set!</button>
                </div>
            </div>

        </div>

        <div id="view-16-dashboard-main" class="view">
            <div class="header">
                <div>
                    <h2>Hello, Alex</h2>
                    <p class="text-muted" id="greeting-subtext">A calm afternoon awaits.</p>
                </div>
                <div style="display: flex; align-items: center; gap: 12px;">
                    <div class="badge" style="background: rgba(24, 112, 244, 0.1); color: var(--primary); border: 1px solid var(--primary-light); font-size: 0.6rem;">🛡️ Privacy Protected</div>
                    <div class="avatar" onclick="navigate('50-profile-settings')">A</div>
                </div>
            </div>

            <div class="glass-card text-center mb-4" style="position:relative; padding-top:30px; padding-bottom:30px;">
                <div class="bg-pulse"></div>
                <h3 class="mb-2" style="position:relative; z-index:2;">Resonance Score</h3>
                <div class="mood-score text-gradient mb-2" id="dash-score"
                    style="font-size: 4.5rem; font-weight: 300; position:relative; z-index:2; line-height:1.1;">--</div>
                <p class="text-primary" id="dash-state"
                    style="font-weight: 500; position:relative; z-index:2; letter-spacing:1px; margin-top:8px;">
                    ANALYZING...</p>
                <p class="text-muted mt-2" id="dash-vagus" style="font-size: 0.8rem; position:relative; z-index:2;">
                    Syncing with biometric sensors.</p>
            </div>

            <div style="position:relative; z-index:50; margin-top: 32px;">
                <h4 class="mb-4" style="font-size: 1.1rem; color:var(--text-main); font-weight:700;">Quick Interventions</h4>
                <div style="display:grid; grid-template-columns: 1fr 1fr; gap:16px; margin-bottom:32px;">
                    <div class="glass-card text-center p-5" onclick="navigate('60-private-mentor')" style="cursor: pointer; border: 2px solid var(--primary); background: white; box-shadow: 0 10px 25px rgba(24, 112, 244, 0.15);">
                        <div style="font-size: 2rem; margin-bottom: 12px;">🧘</div>
                        <div style="font-weight: bold; font-size: 0.9rem; color: var(--primary);">Private Mentor</div>
                    </div>
                    <div class="glass-card text-center p-5" onclick="navigate('21-emotion-home')" style="cursor: pointer; border: 2px solid var(--accent); background: white; box-shadow: 0 10px 25px rgba(255, 209, 59, 0.15);">
                        <div style="font-size: 2rem; margin-bottom: 12px;">🧪</div>
                        <div style="font-weight: bold; font-size: 0.9rem; color: var(--secondary);">Start Analysis</div>
                    </div>
                </div>
            </div>

            <!-- MOOD RECOMMENDATIONS -->
            <div class="glass-card mb-8" id="mood-recs-card" style="display: none; position:relative; z-index:50; border-top: 5px solid var(--primary); background: white;">
                <div class="d-flex justify-content-between align-items-center mb-4">
                    <h4 style="font-size:1.1rem; font-weight:700;">✦ Harmonic Mix</h4>
                    <span id="rec-mood-label" class="badge bg-primary" style="padding: 8px 16px; border-radius: 20px; font-weight:bold;">Balanced</span>
                </div>
                <div id="recommendations-list"></div>
            </div>

            <div class="glass-card mb-4" style="padding: 16px;">
                <h4 class="mb-2" style="font-size:0.95rem;">✦ Subconscious Sync</h4>
                <div
                    style="display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--text-muted); margin-top: 12px;">
                    <span>Pupil Dilation Variance</span>
                    <span class="text-accent" id="dash-pupil" style="font-weight:500;">--</span>
                </div>
                <div
                    style="display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--text-muted); margin-top: 10px;">
                    <span>Micro-Respiration</span>
                    <span class="text-primary" id="dash-resp" style="font-weight:500;">--</span>
                </div>
            </div>

            <div class="glass-card mb-4" style="padding: 16px;">
                <h4 class="mb-2" style="font-size:0.95rem;">🌤️ Environmental Engine</h4>
                <div
                    style="display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--text-muted); margin-top: 12px;">
                    <span>Ambient Noise Stress</span>
                    <span class="text-primary" id="dash-noise" style="font-weight:500;">--</span>
                </div>
                <div
                    style="display: flex; justify-content: space-between; font-size: 0.85rem; color: var(--text-muted); margin-top: 10px;">
                    <span>Barometric Pressure Drop</span>
                    <span class="text-accent" id="dash-pressure" style="font-weight:500;">--</span>
                </div>
            </div>

            <!-- CHATBOT QUICK ACCESS -->
            <button class="btn btn-primary mb-8" onclick="navigate('42-chat-conversation')" style="display:flex; align-items:center; justify-content:center; gap:12px; height: 65px; box-shadow: 0 10px 20px rgba(24, 112, 244, 0.2);">
                <span>💬 Talk to NeuroWell AI</span>
            </button>
        </div>
        <div id="view-17-dashboard-positive" class="view">

            <div class="header">
                <button class="back-btn" onclick="navigate('16-dashboard-main')">←</button>
                <h2>Positive Mood Dashboard</h2>
                <div></div>
            </div>
            <div class="glass-card text-center mt-4"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <img src="logo.png" class="logo-icon mx-auto mb-4"
                    style="width:60px; height:60px; opacity:0.5; filter: grayscale(1); border-radius:50%;">
                <h3>Positive Mood Dashboard</h3>
                <p class="text-muted mt-4">Screen template resting peacefully.</p>
            </div>

        </div>

        <div id="view-18-dashboard-stress" class="view">

            <div class="header">
                <button class="back-btn" onclick="navigate('16-dashboard-main')">←</button>
                <h2>High Stress Dashboard</h2>
                <div></div>
            </div>
            <div class="glass-card text-center mt-4"
                style="flex:1; display:flex; flex-direction:column; justify-content:center;">
                <img src="logo.png" class="logo-icon mx-auto mb-4"
                    style="width:60px; height:60px; opacity:0.5; filter: grayscale(1); border-radius:50%;">
                <h3>High Stress Dashboard</h3>
                <p class="text-muted mt-4">Screen template resting peacefully.</p>
